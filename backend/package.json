{
  "name": "fortress-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fortress demo backend — TypeScript + Express, JSON-on-disk persistence.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "argon2": "^0.44.0",
    "cors": "^2.8.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/cors": "^2.8.19",
    "@types/node": "^25.7.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  }
}
