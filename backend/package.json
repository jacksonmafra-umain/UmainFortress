{
  "name": "fortress-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fortress demo backend — TypeScript + Express, JSON-on-disk persistence.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "express": "^4.21.1",
    "jose": "^5.9.6",
    "argon2": "^0.41.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
